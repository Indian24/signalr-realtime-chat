@{
    var title = ViewData["Title"] ?? "SignalR Chat";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <!-- Inter font (optional, makes UI look SaaS-level) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- Site CSS (versioned) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* optional extra head section from views *@
    @RenderSection("Head", required: false)
</head>
<body>
    <div class="app-root">
        @RenderBody()
    </div>

    <!-- site scripts (core) -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- chat logic (your existing chat.js) -->
    <script src="~/js/chat.js" asp-append-version="true"></script>

    <!-- allow views to add page-specific scripts without crashing -->
    @RenderSection("Scripts", required: false)
</body>
</html>
