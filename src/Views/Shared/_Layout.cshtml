<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<title>SignalR Chat</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#0f172a;
color:#e2e8f0;
font-family: Inter, system-ui, sans-serif;
}

.navbar{
background:#020617;
border-bottom:1px solid #1e293b;
}

.brand{
font-weight:700;
font-size:20px;
color:white;
}

.main-container{
min-height:90vh;
display:flex;
align-items:center;
justify-content:center;
}

.card-modern{
background:#020617;
border:1px solid #1e293b;
border-radius:16px;
padding:40px;
width:420px;
box-shadow:0 10px 30px rgba(0,0,0,.4);
}

.title{
font-size:26px;
font-weight:700;
text-align:center;
margin-bottom:10px;
}

.subtitle{
text-align:center;
color:#94a3b8;
margin-bottom:25px;
}

.form-control{
background:#020617;
border:1px solid #334155;
color:white;
}

.form-control:focus{
background:#020617;
border-color:#3b82f6;
box-shadow:none;
color:white;
}

.btn-primary{
background:#2563eb;
border:none;
width:100%;
padding:10px;
font-weight:600;
}

.btn-primary:hover{
background:#1d4ed8;
}

footer{
text-align:center;
padding:20px;
color:#64748b;
font-size:14px;
}

</style>

</head>

<body>

<nav class="navbar px-4">
<span class="brand">⚡ SignalR Chat</span>
</nav>

<div class="main-container">

@RenderBody()

</div>

<footer>
Real-time Chat • ASP.NET Core • SignalR
</footer>

</body>
</html>